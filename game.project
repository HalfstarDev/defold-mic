[bootstrap]
main_collection = /example/example.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField
package = com.halfstaratelier.micexample

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = Defold-Mic

[library]
include_dirs = mic

[ios]
bundle_identifier = halfstaratelier.micexample

[osx]
bundle_identifier = halfstaratelier.micexample

